{
  "manifest_version": 3,
  "name": "Shorts Remover",
  "version": "1.0",
  "description": "Removes YouTube Shorts and other unwanted elements from YouTube pages",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "icons": {
    "16": "icons/shorts-remover-16.png",
    "48": "icons/shorts-remover-48.png",
    "128": "icons/shorts-remover-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shorts Remover"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
